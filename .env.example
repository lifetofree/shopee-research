# Shopee Affiliate TH — local env template
# Copy to `.env` and populate via `make refresh-cookie`.
# Real values never get committed; `.env` is gitignored.

# --- Shopee storefront session (Surface A) ---
# `; `-joined cookie string for shopee.co.th, captured by `make refresh-cookie`.
SHOPEE_TH_SESSION_COOKIE=

# Exact User-Agent of the browser that produced SHOPEE_TH_SESSION_COOKIE,
# captured by `make refresh-cookie`. Shopee binds session cookies to a
# browser fingerprint; a mismatched UA on a real cookie is rejected with
# `error: 90309999` even though the cookie itself is valid.
SHOPEE_TH_USER_AGENT=

# --- Shopee affiliate portal session (Surface B) ---
# `; `-joined cookie string for affiliate.shopee.co.th.
SHOPEE_TH_AFFILIATE_COOKIE=

# Optional affiliate id; left empty until the empirical capture ticket
# confirms whether an id is required alongside the cookie.
SHOPEE_TH_AFFILIATE_ID=

# --- Output generator ---
# `stub` (default) → TemplateGenerator (deterministic, offline).
# `llm`     → LLMGenerator (Google Gemini; needs SHOPEE_TH_GEMINI_API_KEY).
SHOPEE_TH_GENERATOR=stub

# --- LLM (Google Gemini) — only used when SHOPEE_TH_GENERATOR=llm ---
# Get a free API key at https://aistudio.google.com/apikey
SHOPEE_TH_GEMINI_API_KEY=
# gemini-2.5-flash is on the free tier.
SHOPEE_TH_GEMINI_MODEL=gemini-2.5-flash

# --- Persistence ---
SHOPEE_TH_DB_URL=sqlite+aiosqlite:///./data/shopee_th.db

# --- Observability ---
SHOPEE_TH_LOG_LEVEL=INFO
